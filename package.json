{
  "name": "sliding-puzzle-web",
  "version": "1.0.0",
  "description": "滑块拼图 - HTML5网页版游戏",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy:vercel": "npm run build && vercel --prod",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy dist",
    "deploy:netlify": "npm run build && npx netlify-cli deploy --prod --dir=dist",
    "deploy": "npm run build && wrangler deploy"
  },
  "keywords": [
    "puzzle",
    "game",
    "html5",
    "canvas",
    "sliding-puzzle"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.2",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.1.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.93.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
